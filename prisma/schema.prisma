// apps/api/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  client
  operator
  courier
  admin
}

enum ParcelStatus {
  created
  weighed
  paid
  received_at_origin
  in_batch
  shipped
  in_transit
  customs
  received_at_destination
  sorting
  out_for_delivery
  delivered
}

enum TransportType {
  air
  rail
  sea
  combined
}

enum BatchStatus {
  forming
  shipped
  in_transit
  received
}

enum PaymentProvider {
  click
  payme
  kaspi
  cash
}

enum PaymentStatus {
  pending
  processing
  completed
  failed
  refunded
}

enum WarehouseType {
  origin
  destination
}

enum NotificationChannel {
  telegram
  sms
}

enum NotificationStatus {
  pending
  sent
  failed
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  phone        String   @unique
  name         String
  role         UserRole @default(client)
  passwordHash String?  @map("password_hash")
  telegramId   BigInt?  @map("telegram_id")
  city         String?
  clientCode   String?  @unique @map("client_code")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  warehouseId          String?        @map("warehouse_id") @db.Uuid
  warehouse            Warehouse?     @relation(fields: [warehouseId], references: [id])

  parcels              Parcel[]
  payments             Payment[]
  operatedBatches      Batch[]        @relation("BatchOperator")
  parcelEvents         ParcelEvent[]
  parcelPhotos         ParcelPhoto[]
  sentNotifications    Notification[]
  otpCodes             OtpCode[]

  @@map("users")
}

model OtpCode {
  id        String   @id @default(uuid()) @db.Uuid
  phone     String
  code      String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user   User?   @relation(fields: [userId], references: [id])
  userId String? @map("user_id") @db.Uuid

  @@index([phone, code])
  @@map("otp_codes")
}

model Route {
  id                 String        @id @default(uuid()) @db.Uuid
  originCountry      String        @map("origin_country") @db.VarChar(2)
  destinationCountry String        @map("destination_country") @db.VarChar(2)
  transportType      TransportType @map("transport_type")
  ratePerKg          Decimal       @map("rate_per_kg") @db.Decimal(10, 2)
  minDays            Int           @map("min_days")
  maxDays            Int           @map("max_days")
  isActive           Boolean       @default(true) @map("is_active")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  parcels Parcel[]
  batches Batch[]

  @@unique([originCountry, destinationCountry, transportType])
  @@map("routes")
}

model Parcel {
  id             String       @id @default(uuid()) @db.Uuid
  trackingCode   String       @unique @map("tracking_code")
  userId         String       @map("user_id") @db.Uuid
  routeId        String       @map("route_id") @db.Uuid
  status         ParcelStatus @default(created)
  description    String?
  declaredValue  Decimal?     @map("declared_value") @db.Decimal(10, 2)
  weightKg       Decimal?     @map("weight_kg") @db.Decimal(8, 3)
  lengthCm       Int?         @map("length_cm")
  widthCm        Int?         @map("width_cm")
  heightCm         Int?         @map("height_cm")
  calculatedCost   Decimal?     @map("calculated_cost") @db.Decimal(10, 2)
  finalCost        Decimal?     @map("final_cost") @db.Decimal(10, 2)
  recipientName    String?      @map("recipient_name")
  recipientPhone   String?      @map("recipient_phone")
  recipientAddress String?      @map("recipient_address")
  originCity       String?      @map("origin_city")
  destinationCity  String?      @map("destination_city")
  warehouseId      String?      @map("warehouse_id") @db.Uuid
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id])
  warehouse    Warehouse?    @relation(fields: [warehouseId], references: [id])
  route        Route         @relation(fields: [routeId], references: [id])
  payments     Payment[]
  photos       ParcelPhoto[]
  events       ParcelEvent[]
  batchParcels BatchParcel[]

  @@index([userId])
  @@index([status])
  @@index([trackingCode])
  @@map("parcels")
}

model Batch {
  id             String      @id @default(uuid()) @db.Uuid
  routeId        String      @map("route_id") @db.Uuid
  operatorId     String      @map("operator_id") @db.Uuid
  status         BatchStatus @default(forming)
  totalWeight    Decimal?    @map("total_weight") @db.Decimal(10, 3)
  totalParcels   Int         @default(0) @map("total_parcels")
  trackingNumber String?     @map("tracking_number")
  shippedAt              DateTime?   @map("shipped_at")
  receivedAt             DateTime?   @map("received_at")
  originWarehouseId      String?     @map("origin_warehouse_id") @db.Uuid
  destinationWarehouseId String?     @map("destination_warehouse_id") @db.Uuid
  createdAt              DateTime    @default(now()) @map("created_at")
  updatedAt              DateTime    @updatedAt @map("updated_at")

  route                Route         @relation(fields: [routeId], references: [id])
  operator             User          @relation("BatchOperator", fields: [operatorId], references: [id])
  originWarehouse      Warehouse?    @relation("BatchOrigin", fields: [originWarehouseId], references: [id])
  destinationWarehouse Warehouse?    @relation("BatchDest", fields: [destinationWarehouseId], references: [id])
  batchParcels         BatchParcel[]

  @@index([status])
  @@map("batches")
}

model BatchParcel {
  batchId  String @map("batch_id") @db.Uuid
  parcelId String @map("parcel_id") @db.Uuid

  batch  Batch  @relation(fields: [batchId], references: [id])
  parcel Parcel @relation(fields: [parcelId], references: [id])

  @@id([batchId, parcelId])
  @@map("batch_parcels")
}

model Payment {
  id         String          @id @default(uuid()) @db.Uuid
  parcelId   String          @map("parcel_id") @db.Uuid
  userId     String          @map("user_id") @db.Uuid
  amount     Decimal         @db.Decimal(12, 2)
  currency   String          @default("USD") @db.VarChar(3)
  provider   PaymentProvider
  status     PaymentStatus   @default(pending)
  externalId String?         @map("external_id")
  paidAt     DateTime?       @map("paid_at")
  createdAt  DateTime        @default(now()) @map("created_at")

  parcel Parcel @relation(fields: [parcelId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([parcelId])
  @@index([userId])
  @@map("payments")
}

model ParcelPhoto {
  id       String   @id @default(uuid()) @db.Uuid
  parcelId String   @map("parcel_id") @db.Uuid
  url      String
  takenBy  String   @map("taken_by") @db.Uuid
  takenAt  DateTime @default(now()) @map("taken_at")

  parcel Parcel @relation(fields: [parcelId], references: [id])
  user   User   @relation(fields: [takenBy], references: [id])

  @@index([parcelId])
  @@map("parcel_photos")
}

model ParcelEvent {
  id         String   @id @default(uuid()) @db.Uuid
  parcelId   String   @map("parcel_id") @db.Uuid
  status     String
  location   String?
  operatorId String?  @map("operator_id") @db.Uuid
  note       String?
  timestamp  DateTime @default(now())

  parcel   Parcel @relation(fields: [parcelId], references: [id])
  operator User?  @relation(fields: [operatorId], references: [id])

  @@index([parcelId])
  @@map("parcel_events")
}

model Warehouse {
  id      String        @id @default(uuid()) @db.Uuid
  country String        @db.VarChar(2)
  city    String
  address String
  type    WarehouseType

  operators             User[]
  parcels               Parcel[]
  batchesAsOrigin       Batch[] @relation("BatchOrigin")
  batchesAsDestination  Batch[] @relation("BatchDest")

  @@map("warehouses")
}

model Notification {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  channel   NotificationChannel
  message   String
  status    NotificationStatus  @default(pending)
  sentAt    DateTime?           @map("sent_at")
  createdAt DateTime            @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("notifications")
}
