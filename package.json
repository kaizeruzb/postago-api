{
    "name":  "@postago/api",
    "version":  "0.0.1",
    "private":  true,
    "type":  "module",
    "scripts":  {
                    "dev":  "tsx watch src/index.ts",
                    "build":  "tsup",
                    "test":  "vitest run",
                    "test:watch":  "vitest",
                    "lint":  "tsc --noEmit",
                    "db:push":  "prisma db push",
                    "db:migrate":  "prisma migrate dev",
                    "db:studio":  "prisma studio",
                    "db:seed":  "tsx prisma/seed.ts",
                    "db:generate":  "prisma generate"
                },
    "dependencies":  {
                         "@hono/node-server":  "^1.13.0",
                         "@hono/zod-validator":  "^0.4.0",
                         "@prisma/client":  "^6.3.0",
                         "hono":  "^4.6.0",
                         "bcryptjs":  "^2.4.3",
                         "jsonwebtoken":  "^9.0.2",
                         "nanoid":  "^5.0.0",
                         "zod":  "^3.24.0",
                         "@postago/shared":  "git+https://github.com/kaizeruzb/postago-shared.git"
                     },
    "devDependencies":  {
                            "@types/bcryptjs":  "^2.4.0",
                            "@types/jsonwebtoken":  "^9.0.7",
                            "@types/node":  "^22.0.0",
                            "prisma":  "^6.3.0",
                            "tsup":  "^8.3.0",
                            "tsx":  "^4.19.0",
                            "typescript":  "^5.7.0",
                            "vitest":  "^2.1.0"
                        }
}
